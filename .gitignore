# Devpaper 仓库根 — 依赖、生成物、本机文件

# 依赖
node_modules/

# 包内构建与索引生成物（保留本机即可，不必删）
dist/
logs/index.json
logs/INDEX.md
logs/hub-calendar.json
.demo-logs/
.demo-out/

# 按日手记正文（私有/本机，勿提交 GitHub；克隆后自建或 `npm run sample:logs`）
logs/*.md

# 本机补充长文与答辩材料（自建目录，不入版本库）
docs-local/

# 操作系统
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# 日志与 npm 调试
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# 本地打包产物
*.tgz

# 常见 IDE / 编辑器
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
*~

# 环境变量
.env
.env.local
.env.*.local

# 覆盖率等
coverage/
.nyc_output/
